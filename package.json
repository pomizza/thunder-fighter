{
  "name": "thunder-fighter",
  "version": "1.0.0",
  "description": "纯 HTML5 + JavaScript + Canvas 实现的高质量竖版射击游戏，5 大关卡，3 难度，3 战机，10 成就，0 外部依赖",
  "main": "index.html",
  "scripts": {
    "test": "node tests/runner.cjs",
    "test:config": "node tests/runner.cjs test-config.cjs",
    "test:achievements": "node tests/runner.cjs test-achievements.cjs",
    "test:difficulty": "node tests/runner.cjs test-difficulty.cjs",
    "test:enemies": "node tests/runner.cjs test-enemies.cjs",
    "test:gameflow": "node tests/runner.cjs test-gameflow.cjs",
    "test:performance": "node tests/runner.cjs test-performance.cjs",
    "test:replay": "node tests/runner.cjs test-replay.cjs",
    "test:shipSelect": "node tests/runner.cjs test-shipSelect.cjs",
    "test:shop": "node tests/runner.cjs test-shop.cjs",
    "coverage": "node tests/coverage.cjs",
    "stats": "node tests/coverage.cjs",
    "start": "python3 -m http.server 8000",
    "serve": "python3 -m http.server 8000"
  },
  "keywords": [
    "game",
    "shooting",
    "arcade",
    "shoot-em-up",
    "stg",
    "html5",
    "canvas",
    "vanilla-js",
    "no-dependencies"
  ],
  "author": "Thunder Fighter Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=9.0.0"
  },
  "files": [
    "index.html",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "js/",
    "tests/"
  ],
  "browserslist": [
    "Chrome >= 90",
    "Firefox >= 88",
    "Safari >= 14",
    "Edge >= 90"
  ]
}
